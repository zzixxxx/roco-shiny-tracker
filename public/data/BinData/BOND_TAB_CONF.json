{
  "RocoDataRows": {
    "1": {
      "id": 1,
      "fashion_bond_band": 1,
      "band_name": "暮光歌剧",
      "icon": "PaperSprite'/Game/NewRoco/Modules/System/Appearance/Raw/Frames/img_tab_normal_1_png.img_tab_normal_1_png'",
      "band_long_text": "暮光之中传来微弱的二重奏\n一半是花，一半是引擎。\n他们说，\n那是黄金时代最后的回响，\n也是下一个黎明的前奏。",
      "band_short_text": "浪漫，古典，雅致"
    },
    "2": {
      "id": 2,
      "fashion_bond_band": 2,
      "band_name": "原野空径",
      "icon": "PaperSprite'/Game/NewRoco/Modules/System/Appearance/Raw/Frames/img_tab_normal_2_png.img_tab_normal_2_png'",
      "band_long_text": "今日无大事，一切刚刚好。\n\n字迹很快被风吹散，世界在此刻深呼吸。",
      "band_short_text": "中性，简约，休闲"
    },
    "3": {
      "id": 3,
      "fashion_bond_band": 3,
      "band_name": "昼梦信使",
      "icon": "PaperSprite'/Game/NewRoco/Modules/System/Appearance/Raw/Frames/img_tab_normal_3_png.img_tab_normal_3_png'",
      "band_long_text": "天空某个云层中，有一家只在正午营业的“星辰慢递局”。慢递局的信使是来往的精灵，信件是无主的白日梦，精灵们日日研读信件，妄图用某种力量实现梦。",
      "band_short_text": "自由，幻想，梦境"
    },
    "4": {
      "id": 4,
      "fashion_bond_band": 4,
      "band_name": "第五象限",
      "icon": "PaperSprite'/Game/NewRoco/Modules/System/Appearance/Raw/Frames/img_tab_normal_4_png.img_tab_normal_4_png'",
      "band_long_text": "大魔法师们试图找出一个位于未知空间的孤立坐标，据说那里保存着所有愿望的原始注释。每当有人成功读取该点，因为遗忘而消失的愿望也会重新存在。",
      "band_short_text": "复古，文明，考究"
    },
    "5": {
      "id": 5,
      "fashion_bond_band": 5,
      "band_name": "噪点裂变",
      "icon": "PaperSprite'/Game/NewRoco/Modules/System/Appearance/Raw/Frames/img_tab_normal_5_png.img_tab_normal_5_png'",
      "band_long_text": "一个不该存在的像素突然闪烁，没人知道它是错误，还是恶作剧。狂妄的魔法师嘲笑着正确与制度，在规则的边缘，酷得乱七八糟。\n\n“我庄严宣誓，这一切都是胡言乱语。”",
      "band_short_text": "神秘，怪诞，反叛"
    }
  },
  "LocalizationStrings": {}
}