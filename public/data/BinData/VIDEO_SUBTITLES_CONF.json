{
  "RocoDataRows": {
    "200001": {
      "id": "200001",
      "track_id": "20",
      "begin_time": "00:00:01,200",
      "end_time": "00:00:06,466",
      "content": "为什么……明明没有伤害别人，却还要被囚禁？"
    },
    "200002": {
      "id": "200002",
      "track_id": "20",
      "begin_time": "00:00:06,733",
      "end_time": "00:00:12,300",
      "content": "“那你为什么藏着自己的爪子？为什么不真的让他们害怕你呢？”"
    },
    "200003": {
      "id": "200003",
      "track_id": "20",
      "begin_time": "00:00:13,000",
      "end_time": "00:00:15,866",
      "content": "是啊……既然不相信我……"
    },
    "200004": {
      "id": "200004",
      "track_id": "20",
      "begin_time": "00:00:16,133",
      "end_time": "00:00:17,800",
      "content": "那就都受死吧！"
    },
    "200005": {
      "id": "200005",
      "track_id": "20",
      "begin_time": "00:00:20,533",
      "end_time": "00:00:26,500",
      "content": "“裘卡，控制你自己！好好想想，你究竟想成为怎样的精灵！”"
    },
    "210001": {
      "id": "210001",
      "track_id": "21",
      "begin_time": "00:00:01,566",
      "end_time": "00:00:06,566",
      "content": "他们都不和我玩，我好孤独……好孤独……"
    },
    "210002": {
      "id": "210002",
      "track_id": "21",
      "begin_time": "00:00:07,566",
      "end_time": "00:00:13,333",
      "content": "“让他们也感受你的剧毒吧，这样，他们就会理解你了”"
    },
    "210003": {
      "id": "210003",
      "track_id": "21",
      "begin_time": "00:00:13,566",
      "end_time": "00:00:22,966",
      "content": "对啊……只要大家都和我一样，就不会再害怕我了……我们就能成为朋友了，对不对？"
    },
    "210004": {
      "id": "210004",
      "track_id": "21",
      "begin_time": "00:00:23,566",
      "end_time": "00:00:30,966",
      "content": "请原谅我！我只是……只是想和你们在一起玩……你们会明白的……"
    },
    "210005": {
      "id": "210005",
      "track_id": "21",
      "begin_time": "00:00:31,033",
      "end_time": "00:00:37,066",
      "content": "“珂赛特，醒醒！朋友是靠真心换的……不是强求来的！”"
    },
    "220001": {
      "id": "220001",
      "track_id": "22",
      "begin_time": "00:00:01,233",
      "end_time": "00:00:10,700",
      "content": "我曾竭力为众人争取公平，但最终才明白，没有人真正渴望纯粹的公平"
    },
    "220002": {
      "id": "220002",
      "track_id": "22",
      "begin_time": "00:00:10,200",
      "end_time": "00:00:18,666",
      "content": "“你认为他们在乎的真是公平吗？还是只是伪装下的贪欲？”"
    },
    "220003": {
      "id": "220003",
      "track_id": "22",
      "begin_time": "00:00:18,466",
      "end_time": "00:00:27,000",
      "content": "与其追求虚妄的平衡，还不如放弃这一切，随性而行！"
    },
    "220004": {
      "id": "220004",
      "track_id": "22",
      "begin_time": "00:00:27,533",
      "end_time": "00:00:34,566",
      "content": "希露德，住手吧！倾听你内心深处，那未曾熄灭的秩序之音"
    },
    "230001": {
      "id": "230001",
      "track_id": "23",
      "begin_time": "00:00:00,500",
      "end_time": "00:00:04,500",
      "content": "200年前，当那只怪物侵蚀学院之时"
    },
    "230002": {
      "id": "230002",
      "track_id": "23",
      "begin_time": "00:00:05,167",
      "end_time": "00:00:06,733",
      "content": "我尝试保护大家"
    },
    "230003": {
      "id": "230003",
      "track_id": "23",
      "begin_time": "00:00:08,200",
      "end_time": "00:00:13,467",
      "content": "但冥古龙的噩梦精灵大军，如潮水一般……无穷无尽"
    },
    "230004": {
      "id": "230004",
      "track_id": "23",
      "begin_time": "00:00:14,500",
      "end_time": "00:00:17,900",
      "content": "即使是我，也难以阻挡"
    },
    "230005": {
      "id": "230005",
      "track_id": "23",
      "begin_time": "00:00:19,333",
      "end_time": "00:00:22,567",
      "content": "我只能眼睁睁地看着学院被一步步吞没"
    },
    "230006": {
      "id": "230006",
      "track_id": "23",
      "begin_time": "00:00:23,700",
      "end_time": "00:00:27,333",
      "content": "在万念俱灰时，一位少年现身"
    },
    "230007": {
      "id": "230007",
      "track_id": "23",
      "begin_time": "00:00:28,467",
      "end_time": "00:00:30,033",
      "content": "光芒闪耀间"
    },
    "350001": {
      "id": "350001",
      "track_id": "35",
      "begin_time": "00:01:16,533",
      "end_time": "00:01:17,566",
      "content": "又见面了"
    },
    "350002": {
      "id": "350002",
      "track_id": "35",
      "begin_time": "00:01:18,266",
